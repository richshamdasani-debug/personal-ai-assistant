# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Pricing tier product IDs (create these in Stripe Dashboard)
STRIPE_PRICE_STARTER=price_...   # $15/mo
STRIPE_PRICE_PRO=price_...       # $30/mo
STRIPE_PRICE_MAX=price_...       # $60/mo

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Backend only — never expose to client

# ─── Auth (NextAuth) ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAF...
# Optional: webhook URL for production (ngrok URL in dev)
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/webhooks/telegram

# ─── WhatsApp (Twilio) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Internal API ─────────────────────────────────────────────────────────────
API_PORT=4000
API_SECRET_KEY=generate-with-openssl-rand-hex-32
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Docker / Infrastructure ──────────────────────────────────────────────────
# Max agent containers to run simultaneously (scale per server capacity)
MAX_AGENT_CONTAINERS=50
AGENT_CONTAINER_IMAGE=personal-ai-assistant/agent:latest

# ─── Redis (optional: job queue / pub-sub for agent messages) ─────────────────
REDIS_URL=redis://localhost:6379
